# env/.env.dev.user.example
# Gabarit pour les variables secrètes — versionnées dans Git (exemple seulement)
# ADR-600 — Bootstrap et Gestion de la Configuration
#
# INSTRUCTIONS :
#   1. Copier ce fichier : cp env/.env.dev.user.example env/.env.dev.user
#   2. Remplir les valeurs réelles dans env/.env.dev.user
#   3. NE JAMAIS commiter env/.env.dev.user (il est dans .gitignore)

# ---------------------------------------------------------------------------
# Service Principal Azure (utilisé par Packer pour le build)
# Créer via : az ad sp create-for-rbac --name "sp-smw-packer" --role Contributor
# ---------------------------------------------------------------------------
AZURE_SUBSCRIPTION_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
AZURE_TENANT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
AZURE_CLIENT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
AZURE_CLIENT_SECRET="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# ---------------------------------------------------------------------------
# Publisher Azure Marketplace (ADR-800)
# ---------------------------------------------------------------------------
AZURE_PUBLISHER_ID="votre-publisher-id"

# ---------------------------------------------------------------------------
# SAS Token pour le Blob Storage (optionnel si accès public configuré — ADR-616)
# ---------------------------------------------------------------------------
PACKER_SAS_TOKEN=""
