# env/.env.dev
# Variables d'environnement publiques — versionnées dans Git
# ADR-600 — Bootstrap et Gestion de la Configuration
#
# Ce fichier contient les valeurs non-secrètes du projet.
# Les secrets (AZURE_CLIENT_SECRET, etc.) vont dans env/.env.dev.user (non versionné).
# Copier env/.env.dev.user.example vers env/.env.dev.user et remplir les secrets.

# ---------------------------------------------------------------------------
# Azure Infrastructure (ADR-200)
# ---------------------------------------------------------------------------
AZURE_LOCATION="canadacentral"
AZURE_RESOURCE_GROUP="rg-smw-marketplace"

# ---------------------------------------------------------------------------
# VM de build Packer (ADR-617)
# ---------------------------------------------------------------------------
VM_SIZE="Standard_D4s_v3"

# ---------------------------------------------------------------------------
# Versions du stack logiciel (ADR-001 — versions canoniques, NE PAS modifier)
# ---------------------------------------------------------------------------
SMW_VERSION="6.0.1"
MEDIAWIKI_VERSION="1.43.0"
PHP_VERSION="8.2"
MYSQL_VERSION="8.0"

# ---------------------------------------------------------------------------
# Configuration réseau
# ---------------------------------------------------------------------------
WIKI_HTTP_PORT="80"
WIKI_PORT="443"

# ---------------------------------------------------------------------------
# Blob Storage — Cache de packages (ADR-616)
# ---------------------------------------------------------------------------
BLOB_STORAGE_BASE_URL="https://stsmwmarketplace.blob.core.windows.net/devops"
STORAGE_ACCOUNT="stsmwmarketplace"

# ---------------------------------------------------------------------------
# Azure Compute Gallery — image VM (ADR-617)
# ---------------------------------------------------------------------------
GALLERY_NAME="galSMWMarketplace"
GALLERY_IMAGE_NAME="smw-knowledge-base"
GALLERY_RESOURCE_GROUP="rg-smw-marketplace"
# Publisher de l'image definition — doit correspondre au Partner Center ID (ADR-800)
GALLERY_IMAGE_PUBLISHER="cotechnoe"
